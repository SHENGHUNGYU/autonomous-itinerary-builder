# Travel Planner Agent - Environment Configuration
# Copy to .env and fill in your keys (or set MOCK_TOOLS=1 for development without keys)

# === Mock Mode (HIGHLY RECOMMENDED for early development) ===
MOCK_TOOLS=1
# When 1: All external calls (MCP, Firecrawl, Serp, Google Routes) return deterministic fixtures.
# Realistic Kyushu 5-day self-drive plan that satisfies all constraints.
# Perfect for UI, graph, and validator work before Harper provides API keys.

# === LLM 後端切換 ===
# LLM_BACKEND ∈ {nim, gemini, ollama, vllm}（預設 vllm）
LLM_BACKEND=vllm

# --- NVIDIA NIM（OpenAI 相容端點，LLM_BACKEND=nim 時生效）---
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here   # https://build.nvidia.com
NIM_MODEL=meta/llama-3.1-70b-instruct
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1  # 預設即此

# --- Gemini（OpenAI 相容端點，LLM_BACKEND=gemini 時生效）---
GEMINI_API_KEY=your_gemini_api_key_here    # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  # 預設即此

# === LLM (自架 vLLM / Ollama，OpenAI 相容 API) ===
# vLLM 以 `vllm serve <model> --enable-auto-tool-choice ...` 啟動，提供 /v1 端點
# 若漏填 /v1，程式會自動補上（OpenAI 相容端點在 /v1/chat/completions）
OPENAI_BASE_URL=http://192.168.157.169:8000/v1
OPENAI_API_KEY=EMPTY                       # vLLM 不驗 key，填任意值即可
OPENAI_MODEL=Qwen3-14B-AWQ    # 與 vLLM 載入的模型名稱一致；建議支援 tool-calling 的模型
LLM_MAX_TOKENS=4096           # 未指定任務的「輸出」上限預設；Qwen3 thinking 已預設關閉以省 token
# 各任務的輸出上限（不指定則吃 LLM_MAX_TOKENS）；窗口由 vLLM --max-model-len 決定（可 curl /v1/models 查 max_model_len）
PLANNER_MAX_TOKENS=12288      # 5 天行程 JSON
EXTRACT_MAX_TOKENS=6000       # 研究擷取 JSON（10 景點+15 美食）；太小會在 JSON 閉合前被截 → 擷取失敗
SUPERVISOR_MAX_TOKENS=1024    # 路由決策 JSON 很小

# === 研究擷取（Serper + Firecrawl）視窗 ===
# 窗口夠大（如 64K）時應放大，否則攻略的逐日景點/美食會被截掉 → 只擷取到零星幾筆。
SCRAPE_MAX_URLS=3                   # 每次研究爬幾篇部落格（各自獨立 LLM 呼叫，不佔同一視窗）
SCRAPE_MAX_CHARS_PER_PAGE=24000    # 每頁餵給擷取 LLM 的字數上限；需 < (max_model_len − EXTRACT_MAX_TOKENS)

# === Required API Keys (真實模式 real mode) ===
# Serper（https://serper.dev）：一般關鍵字搜尋 — 撈部落格/社群 URL 給 Firecrawl 解析，
# 以及估算大眾運輸票價 / 景點門票等可搜尋得到的費用
SERPER_API_KEY=your_serper_key_here
# SerpAPI（https://serpapi.com）：僅用於 google_hotels（飯店比價）
SERPAPI_KEY=your_serpapi_key_here
# Google Maps Routes API：每日真實駕車時間 + 距離 + polyline（啟用 Routes API）
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# Firecrawl 解析 Serper 撈到的 URL，做結構化景點/美食擷取（沒有則 fallback mock）
FIRECRAWL_API_KEY=your_firecrawl_key_here
# 機票由 SerpAPI google_flights 提供（與飯店比價共用 SERPAPI_KEY）
# 租車為固定 1500 元/天 mock 估價；大眾運輸/門票費用由 Serper 搜尋估算

# === ReAct 觀察模式（預設關閉）===
# researcher / booker 的 ReAct agent 僅供 LangSmith 觀察「多工具自主編排」，輸出不影響結果，
# 且弱模型常餵幻覺參數（如過去日期）造成 API 400 + 浪費額度。要展示軌跡才開。
RESEARCH_REACT_OBSERVE=0
BOOKER_REACT_OBSERVE=0

# 飯店查詢日期（google_hotels 需要）；UI 帶入實際日期時可忽略
HOTEL_CHECK_IN=2026-06-28
HOTEL_CHECK_OUT=2026-06-29

# Optional but recommended
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=RL
LANGSMITH_TRACING=true

# === Budget / Defaults ===
DEFAULT_BUDGET_TWD=40000
DEFAULT_DAYS=5
DEFAULT_ORIGIN_AIRPORT=TPE        # 機票出發機場（預設台北）

# === Performance ===
REQUEST_TIMEOUT_SECONDS=180   # Planner 生成完整行程約需 40-60s，勿設太短
MAX_RETRIES=3
CACHE_TTL_SECONDS=3600
